{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "lib": ["ES2023"],

    /* Module Resolution */
    "module": "es2022",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@/generated/*": ["./prisma/src/generated/*"]
    },

    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": true,

    /* Completeness */
    "skipLibCheck": true
  }
}