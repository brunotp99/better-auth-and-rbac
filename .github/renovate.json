{
  "extends": ["config:recommended"],
  "minimumReleaseAge": "2 days",
  "dependencyDashboard": true,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Automerge non-major updates (minor & patch)",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["automerge"]
    }
  ]
}
